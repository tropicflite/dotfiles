#!/bin/bash
DOTFILES_DIR="$HOME/dotfiles"
PACKAGES_FILE="$DOTFILES_DIR/packages/packages.txt"
REMOVED_FILE="$DOTFILES_DIR/packages/packages-removed.txt"

# Detect Termux
if [[ -n "$PREFIX" && "$PREFIX" == *termux* ]]; then
  MACHINE="phone"
  SUDO=""
  PKG_CHECK="dpkg -s"
  PKG_INSTALL="apt install -y"
  PKG_REMOVE="apt remove -y"
else
  MACHINE="$(hostname)"
  SUDO="sudo"
  PKG_CHECK="dpkg -s"
  PKG_INSTALL="sudo apt install -y"
  PKG_REMOVE="sudo apt remove -y"
fi

IGNORE_FILE="$DOTFILES_DIR/packages/packages-ignore.$MACHINE"
echo "==> Syncing packages on $MACHINE..."

# Install missing packages
while IFS= read -r pkg || [[ -n "$pkg" ]]; do
  [[ -z "$pkg" || "$pkg" == \#* ]] && continue
  if grep -qx "$pkg" "$REMOVED_FILE" 2>/dev/null; then
    continue
  fi
  if [[ -f "$IGNORE_FILE" ]] && grep -qx "$pkg" "$IGNORE_FILE" 2>/dev/null; then
    continue
  fi
  if ! $PKG_CHECK "$pkg" &>/dev/null; then
    echo "Installing: $pkg"
    $PKG_INSTALL "$pkg"
  fi
done < "$PACKAGES_FILE"

# Remove blacklisted packages
while IFS= read -r pkg || [[ -n "$pkg" ]]; do
  [[ -z "$pkg" || "$pkg" == \#* ]] && continue
  if $PKG_CHECK "$pkg" &>/dev/null; then
    echo "Removing: $pkg"
    $PKG_REMOVE "$pkg"
  fi
done < "$REMOVED_FILE"

echo "==> Done."
