#!/bin/bash
DOTFILES_DIR="$HOME/dotfiles"
PACKAGES_FILE="$DOTFILES_DIR/packages/packages.txt"

if [[ -z "$1" ]]; then
  echo "Usage: packages-push <packagename>"
  exit 1
fi

PKG="$1"

# Check if actually installed
if ! dpkg -s "$PKG" &>/dev/null; then
  echo "==> Error: $PKG is not installed locally."
  exit 1
fi

# Check if already in master list
if grep -qx "$PKG" "$PACKAGES_FILE"; then
  echo "==> $PKG is already in the master list."
  exit 0
fi

# Remove from removed list if present
sed -i "/^${PKG}$/d" "$DOTFILES_DIR/packages/packages-removed.txt"

echo "$PKG" >> "$PACKAGES_FILE"
sort -u "$PACKAGES_FILE" -o "$PACKAGES_FILE"

cd "$DOTFILES_DIR" && git add -A && git commit -m "packages-push: add ${PKG} from $(hostname)" && git push
echo "==> $PKG added to master list and pushed."
