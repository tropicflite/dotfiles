# Desktop-specific config (WSL2)
PROMPT="%{$fg[$NCOLOR]%}%B%n@$_MACHINE%b%{$reset_color%}:%{$fg[blue]%}%B%c/%b%{$reset_color%} $(git_prompt_info)%(!.#.$) "

# Tailscale (runs on Windows, not in WSL2)
alias tsstatus='echo "Tailscale: check Windows system tray"'


# Desktop-specific locale
[ -f /etc/default/locale ] && source /etc/default/locale
cd ~
