# Phone-specific config
# Package management (Termux)
alias pks="pkg search"
alias pki="pkg install"
alias pku="pkg upgrade"
# Tailscale (Termux — no tailscale command in PATH)
alias tsstatus='echo "Tailscale: check Android app (Settings → Tailscale)"'
alias netstatus='tsstatus && echo "ProtonVPN: check Android app"'
# Git SSH key
export GIT_SSH_COMMAND='ssh -i ~/.ssh/id_ed25519'
export OLLAMA_HOST=http://100.78.51.10:11434
