# Server-specific config
MACHINE_NAME="server"
PROMPT="%{$fg[$NCOLOR]%}%B%n@$MACHINE_NAME%b%{$reset_color%}:%{$fg[blue]%}%B%c/%b%{$reset_color%} $(git_prompt_info)%(!.#.$) "
# Tailscale (server-specific with hostname flag)
alias tson='sudo tailscale up --hostname=server'
alias tsoff='sudo tailscale down'
# Network
alias netstatus="tsstatus; vpnstatus"
# Reload local file
alias szl='source ~/.zshrc.local.server'
vpnstatus() {
  local wg_out
  wg_out=$(sudo wg show wg0 2>/dev/null)
  if [[ -z "$wg_out" ]]; then
    echo "WireGuard: DOWN (interface missing)"
    return
  fi
  local handshake
  handshake=$(echo "$wg_out" | grep "latest handshake" | awk '{print $3, $4, $5, $6}')
  local transfer
  transfer=$(echo "$wg_out" | grep "transfer" | awk '{print $2, $3, $4, $5, $6, $7}')
  echo "WireGuard: UP"
  [[ -n "$handshake" ]] && echo "  Last handshake: $handshake"
  [[ -n "$transfer" ]] && echo "  Transfer: $transfer"
}
export OLLAMA_HOST=http://100.78.51.10:11434
# Tailscale Funnel / FileBrowser toggle
fbon() {
  tailscale funnel reset
  tailscale serve reset
  tailscale serve --bg --https=8081 http://localhost:8081
  tailscale serve --bg --https=8082 http://localhost:8080
  tailscale serve --bg --https=8090 http://localhost:8091
  tailscale serve --bg --https=8097 http://localhost:8096
  tailscale serve --bg --https=2283 http://localhost:2283
  tailscale serve --bg --https=3000 http://localhost:3001
  tailscale funnel --bg --https=443 http://127.0.0.1:8081
  echo "Funnel ON — FileBrowser public on 443"
}
fboff() {
  tailscale funnel reset
  tailscale serve reset
  tailscale serve --bg --https=443 http://127.0.0.1:8083
  tailscale serve --bg --https=8081 http://localhost:8081
  tailscale serve --bg --https=8082 http://localhost:8080
  tailscale serve --bg --https=8090 http://localhost:8091
  tailscale serve --bg --https=8097 http://localhost:8096
  tailscale serve --bg --https=2283 http://localhost:2283
  tailscale serve --bg --https=3000 http://localhost:3001
  echo "Funnel OFF — Open WebUI on 443"
}

fbstatus() {
  tailscale serve status | grep -E "Funnel|443"
}
