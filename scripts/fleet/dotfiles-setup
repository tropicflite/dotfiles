#!/usr/bin/env zsh
# Symlink dotfiles into place for the current machine

DOTFILES="$HOME/dotfiles"
IS_PHONE=false
[[ -n "$PREFIX" ]] && IS_PHONE=true

# Helper
lns() {
  local src="$1" dst="$2"
  mkdir -p "$(dirname "$dst")"
  ln -sfn "$src" "$dst"
  echo "linked: $dst -> $src"
}

# Universal
lns "$DOTFILES/zsh/.zshrc" "$HOME/.zshrc"
lns "$DOTFILES/.config/nvim" "$HOME/.config/nvim"
lns "$DOTFILES/.config/ranger" "$HOME/.config/ranger"
lns "$DOTFILES/ssh/config" "$HOME/.ssh/config"
lns "$DOTFILES/tmux/tmux.conf" "$HOME/.tmux.conf"

# Machine-specific .zshrc.local
MACHINE=$(echo "${HOST%%.*}" | tr '[:upper:]' '[:lower:]')
$IS_PHONE && MACHINE=phone
local_zshrc="$DOTFILES/zsh/.zshrc.local.$MACHINE"
[[ -f "$local_zshrc" ]] && lns "$local_zshrc" "$HOME/.zshrc.local.$MACHINE"

# Non-phone only
if ! $IS_PHONE; then
  lns "$DOTFILES/.config/btop" "$HOME/.config/btop"
  lns "$DOTFILES/.config/kitty" "$HOME/.config/kitty"
  lns "$DOTFILES/.claude/statusline-command.sh" "$HOME/.claude/statusline-command.sh"
fi

# i3 machines (laptop, mini)
if [[ "$MACHINE" == "laptop" || "$MACHINE" == "mini" ]]; then
  lns "$DOTFILES/.Xmodmap" "$HOME/.Xmodmap"
fi

# server only
if [[ "$MACHINE" == "server" ]]; then
  lns "$DOTFILES/scripts/server/docker-CLAUDE.md" "$HOME/docker/CLAUDE.md"
fi
# Ollama client binary (non-phone, non-desktop)
if ! $IS_PHONE && [[ "$MACHINE" != "desktop" ]]; then
  if ! command -v ollama &>/dev/null; then
    echo "Installing ollama binary..."
    OLLAMA_VERSION=$(curl -sL https://api.github.com/repos/ollama/ollama/releases/latest | grep '"tag_name"' | cut -d'"' -f4)
    curl -L "https://github.com/ollama/ollama/releases/download/${OLLAMA_VERSION}/ollama-linux-amd64.tar.zst" -o /tmp/ollama.tar.zst
    tar -xf /tmp/ollama.tar.zst -C /tmp
    sudo install /tmp/bin/ollama /usr/local/bin/ollama
    rm -rf /tmp/ollama.tar.zst /tmp/bin /tmp/lib
    echo "ollama ${OLLAMA_VERSION} installed."
  else
    echo "ollama already installed, skipping."
  fi
fi
echo "Done."
