#!/bin/bash
# WSL2 wrapper: routes arecord through PulseAudio (RDPSource via WSLg).
# Claude Code's voice mode probes for arecord but WSL2 has no ALSA kernel
# modules. This wrapper satisfies the probe and captures real mic audio.

if [[ "$1" == "--version" ]]; then
    echo "arecord: version 1.2.13 (WSL2/PulseAudio wrapper)"
    exit 0
fi

# Probe: arecord ... /dev/null — just confirm we can start
for arg in "$@"; do
    [[ "$arg" == "/dev/null" ]] && exit 0
done

# Parse -r (rate) and -c (channels) from args; ignore the rest
RATE=16000
CHANNELS=1
prev=""
for arg in "$@"; do
    case "$prev" in
        -r) RATE="$arg" ;;
        -c) CHANNELS="$arg" ;;
    esac
    prev="$arg"
done

# Capture at PulseAudio's native rate (avoids internal resampling),
# then use ffmpeg's soxr resampler to downsample to the requested rate.
PULSE_RATE=44100
parec \
    --format=s16le \
    --rate="$PULSE_RATE" \
    --channels="$CHANNELS" \
    --raw \
    --device=RDPSource \
| ffmpeg \
    -f s16le -ar "$PULSE_RATE" -ac "$CHANNELS" -i pipe:0 \
    -f s16le -ar "$RATE"       -ac "$CHANNELS" \
    -af "aresample=resampler=soxr" \
    -loglevel quiet \
    pipe:1
